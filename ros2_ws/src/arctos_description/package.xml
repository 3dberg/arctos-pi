<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>arctos_description</name>
  <version>0.1.0</version>
  <description>URDF/xacro description for the Arctos 6-axis arm. Geometry uses
    the real CAD STL meshes (ported from the legacy ROS1 arctos_urdf_description,
    mm-scale); joint limits are generated from the arctos-pi config via
    backend.ros_export.</description>
  <maintainer email="tencho.tenchev@3dberg.com">3dberg</maintainer>
  <license>TBD</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <exec_depend>xacro</exec_depend>
  <exec_depend>robot_state_publisher</exec_depend>
  <exec_depend>joint_state_publisher_gui</exec_depend>
  <exec_depend>rviz2</exec_depend>
  <exec_depend>ros2_control</exec_depend>
  <exec_depend>controller_manager</exec_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
